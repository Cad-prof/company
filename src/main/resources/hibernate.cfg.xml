<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>

        <!-- PostgreSQL connection -->
        <property name="hibernate.connection.driver_class">org.postgresql.Driver</property>
        <property name="hibernate.connection.url">jdbc:postgresql://localhost:5432/company_db</property>
        <property name="hibernate.connection.username">postgres</property>
        <property name="hibernate.connection.password">your_password</property>

        <!-- Hibernate 6: dialect is auto-detected, but explicit is safer -->
        <property name="hibernate.dialect">org.hibernate.dialect.PostgreSQLDialect</property>

        <!-- Auto-create/update tables from entities -->
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- Show SQL in console (useful while developing) -->
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>

        <!-- Connection pool (built-in, good enough for a TP) -->
        <property name="hibernate.connection.pool_size">5</property>

        <!-- Entity mappings -->
        <mapping class="com.groupeisi.company.entities.Product"/>
        <mapping class="com.groupeisi.company.entities.Purchases"/>
        <mapping class="com.groupeisi.company.entities.Sales"/>

    </session-factory>
</hibernate-configuration>